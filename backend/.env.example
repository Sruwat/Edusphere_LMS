# Django runtime
DJANGO_SECRET_KEY=replace-with-a-strong-secret
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:8001,http://127.0.0.1:8001
LOG_LEVEL=INFO
USE_SQLITE_FOR_TESTS=1

# MySQL settings
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=sarasedu
MYSQL_USER=sarasedu
MYSQL_PASSWORD=password

# Django DB env used by settings
DB_NAME=${MYSQL_DATABASE}
DB_USER=${MYSQL_USER}
DB_PASSWORD=${MYSQL_PASSWORD}
DB_HOST=127.0.0.1
DB_PORT=3306

# Frontend origin (for CORS)
CORS_ALLOWED_ORIGIN=http://localhost:5000,http://127.0.0.1:5000

# MinIO / S3 (for file uploads)
USE_S3=0
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=sarasedu
MINIO_SECURE=0
MEDIA_PUBLIC_URL=http://127.0.0.1:8000/media/

# AI provider keys (optional)
OPENROUTER_API_KEY=
ASSEMBLY_API_KEY=
