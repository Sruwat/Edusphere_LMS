DJANGO_SECRET_KEY=replace-with-a-strong-secret
DEBUG=0
ALLOWED_HOSTS=lms.example.com,api.example.com
CSRF_TRUSTED_ORIGINS=https://lms.example.com,https://api.example.com
LOG_LEVEL=INFO
USE_SQLITE_FOR_TESTS=1

DB_NAME=sarasedu
DB_USER=sarasedu
DB_PASSWORD=replace-with-db-password
DB_HOST=db
DB_PORT=3306
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt

CORS_ALLOWED_ORIGIN=https://lms.example.com

USE_S3=1
MINIO_ENDPOINT=your-account-id.r2.cloudflarestorage.com
MINIO_PUBLIC_ENDPOINT=https://pub-your-public-bucket-id.r2.dev
MINIO_ACCESS_KEY=replace-with-r2-access-key
MINIO_SECRET_KEY=replace-with-r2-secret-key
MINIO_BUCKET=edusphere-media
MINIO_SECURE=1
MEDIA_PUBLIC_URL=https://files.example.com/media/

# Optional S3-compatible storage settings for providers like Supabase.
# Example:
# STORAGE_ENDPOINT_URL=https://your-project.supabase.co/storage/v1/s3
# STORAGE_PUBLIC_BASE_URL=https://your-project.supabase.co/storage/v1/object/public/edusphere-media
# MINIO_ACCESS_KEY=replace-with-s3-access-key
# MINIO_SECRET_KEY=replace-with-s3-secret-key
# MINIO_BUCKET=edusphere-media

OPENROUTER_API_KEY=
ASSEMBLY_API_KEY=
